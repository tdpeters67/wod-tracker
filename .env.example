# Copy to .env.local for local dev, and set these in the Vercel project settings.

# Turso / libSQL connection.
# Local dev: use "file:local.db" and leave TURSO_AUTH_TOKEN blank.
# Production: from `turso db show <db> --url` and `turso db tokens create <db>`.
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# The single shared password that gates the whole site.
APP_PASSWORD=change-me

# Secret used to sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=change-me
